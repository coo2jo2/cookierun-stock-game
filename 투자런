<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>쿠키 투자런</title>
    <style>
        body { background: #222; color: white; font-family: sans-serif; text-align: center; padding: 20px; }
        .game-board { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; max-width: 800px; margin: 0 auto; }
        .company-card { background: #333; padding: 15px; border-radius: 10px; border: 2px solid #555; }
        
        /* 이미지가 표시되는 곳 (c1~c4 -> r 로 교체) */
        .status-img { width: 100%; height: 200px; background: #000; margin-bottom: 10px; object-fit: contain; }
        
        .input-group { margin-top: 10px; }
        input { width: 80%; padding: 8px; border-radius: 5px; border: none; text-align: center; font-size: 1.1em; }
        
        .info-panel { margin: 30px 0; padding: 20px; background: #444; border-radius: 10px; }
        .info-btn { background: #f39c12; color: white; border: none; padding: 10px 20px; margin: 5px; cursor: pointer; border-radius: 5px; }
        
        .next-btn { background: #27ae60; color: white; border: none; padding: 20px 40px; font-size: 1.5em; cursor: pointer; border-radius: 10px; margin-top: 30px; width: 100%; max-width: 800px; }
        h2 { color: #f1c40f; }
    </style>
</head>
<body>

    <h1>💰 쿠키 투자런 (21억 도전)</h1>
    <h2>현재 회차: <span id="turn-display">1</span> / 7</h2>

    <div class="game-board">
        <!-- 뮤직엔터 (c1) -->
        <div class="company-card">
            <img id="img-c1" src="resources/results/c1.png" class="status-img">
            <h3>뮤직엔터</h3>
            <div class="input-group">
                <input type="number" id="invest-c1" placeholder="투자 금액 입력">
            </div>
        </div>

        <!-- 포춘시스터즈 (c2) -->
        <div class="company-card">
            <img id="img-c2" src="resources/results/c2.png" class="status-img">
            <h3>포춘시스터즈</h3>
            <div class="input-group">
                <input type="number" id="invest-c2" placeholder="투자 금액 입력">
            </div>
        </div>

        <!-- 연금전자 (c3) -->
        <div class="company-card">
            <img id="img-c3" src="resources/results/c3.png" class="status-img">
            <h3>연금전자</h3>
            <div class="input-group">
                <input type="number" id="invest-c3" placeholder="투자 금액 입력">
            </div>
        </div>

        <!-- 마카로즈 (c4) -->
        <div class="company-card">
            <img id="img-c4" src="resources/results/c4.png" class="status-img">
            <h3>마카로즈</h3>
            <div class="input-group">
                <input type="number" id="invest-c4" placeholder="투자 금액 입력">
            </div>
        </div>
    </div>

    <div class="info-panel">
        <h3>📂 획득 가능한 정보</h3>
        <div id="info-list">
            <!-- 클릭해야만 볼 수 있는 버튼들 -->
        </div>
    </div>

    <button id="main-btn" class="next-btn" onclick="showResult()">1회차 결과 보기</button>

<script>
    let turn = 1;
    // 가람님의 r 로직 매핑 (예시: 뮤직엔터 1회차 결과는 r22)
    const resultMapping = {
        1: { c1: 'r22', c2: 'r1', c3: 'r10', c4: 'r1' },
        2: { c1: 'r23', c2: 'r2', c3: 'r11', c4: 'r2' },
        // ... 가람님이 알려준 r1~r28을 여기에 다 넣으면 됨
    };

    const infoFiles = [
        "HBS 기사 셈플.pdf", "직비모 캡쳐 파일.pdf", "포춘쿠키런 카페 유저들 대화.pdf",
        "쿠키팝 팬들 커뮤니티.pdf", "제목.pdf", "마카로즈 기사 (폐기하세요).pdf", "쿠스패치 단독 기사.pdf"
    ];

    // 결과 보기 버튼 클릭 시
    function showResult() {
        const mapping = resultMapping[turn];
        
        // 이미지 교체 로직
        document.getElementById('img-c1').src = `resources/results/${mapping.c1}.png`;
        document.getElementById('img-c2').src = `resources/results/${mapping.c2}.png`;
        document.getElementById('img-c3').src = `resources/results/${mapping.c3}.png`;
        document.getElementById('img-c4').src = `resources/results/${mapping.c4}.png`;

        // 정보 버튼 생성
        const infoList = document.getElementById('info-list');
        const btn = document.createElement('button');
        btn.className = "info-btn";
        btn.innerText = `📄 정보 ${turn} 확인하기`;
        btn.onclick = () => window.open(`resources/data/${infoFiles[turn-1]}`, '_blank');
        infoList.appendChild(btn);

        // 다음 회차 준비
        const mainBtn = document.getElementById('main-btn');
        if (turn < 7) {
            mainBtn.innerText = `${turn + 1}회차 준비하기`;
            mainBtn.onclick = prepareNextTurn;
        } else {
            mainBtn.innerText = "최종 투자 종료";
            mainBtn.disabled = true;
        }
    }

    // 다음 회차 준비 (다시 c1~c4로 초기화할지, 그대로 둘지 선택 가능)
    function prepareNextTurn() {
        turn++;
        document.getElementById('turn-display').innerText = turn;
        
        // 다시 입력받기 위해 버튼 멘트 변경
        const mainBtn = document.getElementById('main-btn');
        mainBtn.innerText = `${turn}회차 결과 보기`;
        mainBtn.onclick = showResult;
        
        // 입력창 비우기 (선택 사항)
        document.querySelectorAll('input').forEach(input => input.value = "");
    }
</script>
</body>
</html>
